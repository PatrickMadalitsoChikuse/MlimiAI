# --- AI model inference ---
# English model is used by default. Add a separate Chichewa model later.
ENGLISH_MODEL_URL=https://revenge-kelp-reword.ngrok-free.dev/chat
ENGLISH_MODEL_NAME=english-agriculture-model
MODEL_TIMEOUT_SECONDS=120

# --- Flask ---
PORT=5050

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# --- Default users (seeded on first run if missing) ---
# The default admin's email is ALWAYS treated as admin, even if ADMIN_EMAILS is empty.
DEFAULT_ADMIN_EMAIL=admin@mlimi.local
DEFAULT_ADMIN_NAME=Mlimi Admin
DEFAULT_ADMIN_PASSWORD=admin12345

# Optional extra test user. Set SEED_DEFAULT_USER=0 to skip.
DEFAULT_USER_EMAIL=farmer@mlimi.local
DEFAULT_USER_NAME=Test Farmer
DEFAULT_USER_PASSWORD=farmer12345
SEED_DEFAULT_USER=1

# Extra admin emails (comma-separated). The DEFAULT_ADMIN_EMAIL is always included.
ADMIN_EMAILS=
